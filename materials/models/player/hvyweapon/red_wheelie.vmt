VertexLitGeneric
{
	$basetexture "models/player/hvyweapon/red_wheelie"
	$bumpmap "models/player/hvyweapon/hvyweapon_normal"

	$lightwarptexture "models/player/pyro/pyro_lightwarp"

	$detail "effects/tiledfire/firelayeredslowtiled512"
	$detailblendmode 6
	$detailscale 5
	$detailblendfactor 0.01

	$phong 1
	$phongfresnelranges "[0.3 1 8]"
	$phongexponent 20
	$phongboost 0.3

	$rimlight 1
	$rimlightexponent 4
	$rimlightboost 2

	$cloakpassenabled 1
	$one 1
	$yellow 0
	360?$color2 "[ 0.8 0.8 0.8 ]"

	Proxies
	{
		spy_invis
		{
		}

		AnimatedTexture
		{
			animatedtexturevar "$detail"
			animatedtextureframenumvar "$detailframe"
			animatedtextureframerate 30
		}

		BurnLevel
		{
			resultVar "$detailblendfactor"
		}

		YellowLevel
		{
			resultVar "$yellow"
		}

		Equals
		{
			srcVar1 "$yellow"
			resultVar "$color2"
		}
	}
}